{
  "manifest_version": 3,
  "name": "Notes",
  "version": "1.0.4",
  "description": "A simple note-taking extension for Firefox",
  "permissions": ["storage"],
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Open Notes"
  },
  "icons": {
    "128": "src/icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "notes-extension@example.com",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; style-src 'self' 'unsafe-inline';"
  }
}
